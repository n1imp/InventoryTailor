# Database Configuration
# DATABASE_PROVIDER: 'sqlite' or 'postgresql'
DATABASE_PROVIDER=sqlite
# DATABASE_URL: Connection string for the database
# SQLite example: file:./dev.db
# PostgreSQL example: postgresql://user:password@localhost:5432/dbname?schema=public
DATABASE_URL=file:./dev.db

# JWT_SECRET: Secret key for signing JSON Web Tokens.
# AI Studio automatically injects GEMINI_API_KEY at runtime, which is used as a fallback.
JWT_SECRET="your-super-secret-key"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# Email Configuration (Resend)
RESEND_API_KEY=re_...

# Monitoring (Sentry)
SENTRY_DSN=https://...
VITE_SENTRY_DSN=https://...

# Security
TASK_SECRET=a-long-random-string-for-internal-tasks

# Environment
NODE_ENV=production
